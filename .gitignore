# Ignore environment variable files
.env 

# Add logs/ to the .gitignore file to prevent log files from being committed to the repository.
logs/ 

# Python build artifacts
*.egg-info/
build/
dist/
__pycache__/
*.pyc

# VSCode settings
.vscode/

# Test cache
.pytest_cache/

# Ignore virtual environments
venv/ 

# OS-specific
.DS_Store

# IDE & Editor files
.claude/

# Logs
logs/*.log
!logs/.gitkeep 